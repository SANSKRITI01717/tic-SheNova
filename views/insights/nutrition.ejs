<%- include('../partials/head', { title: 'Nutrition' }) %>
<%- include('../partials/navbar', { activePage: 'nutrition' }) %>

<div class="app-layout">
  <%- include('../partials/sidebar', { activePage: 'nutrition' }) %>
  <main class="main-content">
    <div class="flex justify-between items-center mb-3">
      <div>
        <h1 style="font-family:var(--font-display);font-size:1.6rem;">🥗 Nutrition Tracker</h1>
        <p class="text-muted text-sm">Log your meals and hydration for today</p>
      </div>
    </div>

    <div class="grid-2" style="align-items:start;">
      <!-- Today Summary -->
      <div style="display:flex;flex-direction:column;gap:1.25rem;">

        <!-- Water tracker -->
        <div class="card fade-up">
          <div class="card-header">
            <div class="card-title">💧 Water Intake</div>
            <span class="text-sm text-muted">Goal: 8 glasses/day</span>
          </div>
          <div class="water-tracker" id="waterTracker">
            <% const filled = todayLog ? todayLog.waterGlasses : 0; %>
            <% for (let i = 0; i < 10; i++) { %>
            <div class="water-glass <%= i < filled ? 'filled' : '' %>" data-index="<%= i %>"></div>
            <% } %>
          </div>
          <div class="mt-2 text-sm text-muted"><span id="waterCount" style="font-weight:700;color:var(--teal-600);font-size:1.1rem;"><%= filled %></span> / 8 glasses today</div>
          <button class="btn btn-outline btn-sm mt-2" onclick="logWater()">+ Add a glass</button>
        </div>

        <!-- Daily totals -->
        <div class="card fade-up fade-up-2">
          <div class="card-header"><div class="card-title">📊 Today's Totals</div></div>
          <div style="display:flex;flex-direction:column;gap:1rem;">
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span>Calories</span>
                <span class="fw-600"><%= todayLog ? todayLog.totalCalories : 0 %> / 1800 kcal</span>
              </div>
              <div class="progress-bar-wrap">
                <div class="progress-bar-fill amber" style="width:<%= todayLog ? Math.min(todayLog.totalCalories/1800*100,100) : 0 %>%"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span>Protein</span>
                <span class="fw-600"><%= todayLog ? todayLog.totalProtein : 0 %>g / 60g</span>
              </div>
              <div class="progress-bar-wrap">
                <div class="progress-bar-fill" style="width:<%= todayLog ? Math.min(todayLog.totalProtein/60*100,100) : 0 %>%"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span>Water</span>
                <span class="fw-600"><%= filled %> / 8 glasses</span>
              </div>
              <div class="progress-bar-wrap">
                <div class="progress-bar-fill rose" style="width:<%= Math.min(filled/8*100,100) %>%"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Meals logged today -->
        <div class="card fade-up fade-up-3">
          <div class="card-header"><div class="card-title">🍽️ Meals Today</div></div>
          <% if (todayLog && todayLog.meals.length > 0) { %>
          <% todayLog.meals.forEach(meal => { %>
          <div style="padding:0.65rem 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;">
            <div>
              <div class="fw-600 text-sm"><%= meal.name %></div>
              <div class="text-sm text-muted"><%= meal.time || '' %></div>
            </div>
            <div style="text-align:right;">
              <div class="text-sm fw-600 text-teal"><%= meal.calories %> kcal</div>
              <div class="text-sm text-muted"><%= meal.protein %>g protein</div>
            </div>
          </div>
          <% }) %>
          <% } else { %>
          <div class="empty-state" style="padding:1.5rem 0;">
            <div class="empty-icon">🍽️</div>
            <p>No meals logged today</p>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Add meal form -->
      <div class="card fade-up fade-up-2" style="position:sticky;top:80px;">
        <div class="card-header"><div class="card-title">➕ Log a Meal</div></div>
        <form action="/insights/nutrition/meal" method="POST">
          <div class="form-group">
            <label>Meal Name</label>
            <input type="text" name="name" placeholder="e.g. Dal Chawal, Banana, Salad..." required>
          </div>
          <div class="form-group">
            <label>Time</label>
            <select name="time">
              <option value="Breakfast">🌅 Breakfast</option>
              <option value="Morning Snack">☕ Morning Snack</option>
              <option value="Lunch" selected>☀️ Lunch</option>
              <option value="Evening Snack">🍵 Evening Snack</option>
              <option value="Dinner">🌙 Dinner</option>
            </select>
          </div>
          <div class="grid-2" style="gap:0.75rem;">
            <div class="form-group">
              <label>Calories (kcal)</label>
              <input type="number" name="calories" min="0" max="2000" placeholder="350" required>
            </div>
            <div class="form-group">
              <label>Protein (g)</label>
              <input type="number" name="protein" min="0" max="200" placeholder="12">
            </div>
            <div class="form-group">
              <label>Carbs (g)</label>
              <input type="number" name="carbs" min="0" max="500" placeholder="50">
            </div>
            <div class="form-group">
              <label>Fat (g)</label>
              <input type="number" name="fat" min="0" max="200" placeholder="8">
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-block">🥗 Log Meal</button>
        </form>

        <!-- Phase-based food tips -->
        <div style="margin-top:1.5rem;padding:1rem;background:var(--teal-50);border-radius:var(--radius-sm);">
          <div class="text-sm fw-600 mb-1 text-teal">💡 Today's Nutrition Tip</div>
          <div class="text-sm text-muted">Focus on iron-rich foods like spinach, lentils, and dates during your menstrual phase. Avoid excessive caffeine and salty processed foods.</div>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
async function logWater() {
  const res = await fetch('/insights/nutrition/water', { method: 'POST' });
  if (res.ok) {
    const data = await res.json();
    const glasses = document.querySelectorAll('.water-glass');
    glasses.forEach((g, i) => g.classList.toggle('filled', i < data.waterGlasses));
    document.getElementById('waterCount').textContent = data.waterGlasses;
  }
}

// Water glass click
document.querySelectorAll('.water-glass').forEach((g, i) => {
  g.addEventListener('click', logWater);
});
</script>

<%- include('../partials/footer') %>
