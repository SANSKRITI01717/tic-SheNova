<%- include('../partials/head', { title: 'Cycle Log' }) %>
<%- include('../partials/navbar', { activePage: 'cycle' }) %>

<div class="app-layout">
  <%- include('../partials/sidebar', { activePage: 'cycle' }) %>
  <main class="main-content">
    <% if (locals.flash) { %>
    <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <div class="flex justify-between items-center mb-3">
      <div>
        <h1 style="font-family:var(--font-display);font-size:1.6rem;background:linear-gradient(135deg,var(--lav-700),#c026d3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
          🌸 Cycle Log
        </h1>
        <p class="text-muted text-sm">Track your period, symptoms, mood and energy</p>
      </div>
      <div style="font-size:0.82rem;color:var(--lav-600);background:var(--lav-50);border:1px solid var(--lav-200);padding:0.4rem 0.9rem;border-radius:99px;font-weight:600;">
        💜 Every log helps your insights
      </div>
    </div>

    <div class="grid-2" style="align-items:start;">

      <!-- ── LOG FORM ── -->
      <div class="card fade-up" style="border-color:var(--lav-200);">
        <div class="card-header">
          <div class="card-title" style="background:linear-gradient(135deg,var(--lav-600),#c026d3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
            ➕ Log New Entry
          </div>
          <span style="font-size:1.4rem;animation:petalSway 3s ease-in-out infinite;display:inline-block;">🌸</span>
        </div>

        <style>
          @keyframes petalSway {
            0%,100% { transform: rotate(-8deg); }
            50%      { transform: rotate(8deg); }
          }
          /* form card inputs */
          .cycle-form input[type="date"],
          .cycle-form select,
          .cycle-form textarea {
            border: 1.5px solid var(--lav-200);
            border-radius: 12px;
            background: rgba(245,240,255,0.5);
            transition: all 0.2s;
          }
          .cycle-form input[type="date"]:focus,
          .cycle-form select:focus,
          .cycle-form textarea:focus {
            border-color: var(--lav-400);
            background: white;
            box-shadow: 0 0 0 4px rgba(139,92,246,0.1);
          }
          .cycle-form label {
            font-size: 0.82rem; font-weight: 700;
            color: var(--lav-800); margin-bottom: 0.4rem;
          }
          /* option cards inside cycle form */
          .cycle-form .option-card {
            border: 2px solid var(--lav-100);
            border-radius: 12px; background: white;
            transition: all 0.2s;
          }
          .cycle-form .option-card:hover {
            border-color: var(--lav-300);
            background: linear-gradient(135deg, var(--lav-50), #fce7f3);
            transform: translateY(-2px);
          }
          .cycle-form .option-card:has(input:checked) {
            border-color: var(--lav-500);
            background: linear-gradient(135deg, var(--lav-100), #fce7f3);
            box-shadow: 0 3px 12px rgba(139,92,246,0.15);
          }
          .cycle-form .option-card:has(input:checked)::after {
            content: '✓'; position: absolute; top: 5px; right: 7px;
            width: 16px; height: 16px; border-radius: 50%;
            background: linear-gradient(135deg, var(--lav-500), #c026d3);
            color: white; font-size: 0.6rem; font-weight: 700;
            display: flex; align-items: center; justify-content: center;
          }
          /* mood buttons */
          .mood-btn {
            border: 1.5px solid var(--lav-200);
            border-radius: 99px; background: white;
            color: var(--text-muted); font-size: 0.82rem;
            padding: 0.4rem 0.9rem; cursor: pointer; transition: all 0.2s;
          }
          .mood-btn:hover {
            border-color: var(--lav-400);
            background: var(--lav-50); color: var(--lav-700);
          }
          .mood-btn.active {
            background: linear-gradient(135deg, var(--lav-500), #c026d3);
            border-color: transparent; color: white;
            box-shadow: 0 3px 12px rgba(139,92,246,0.3);
          }
          /* range sliders */
          .cycle-form input[type="range"] {
            accent-color: var(--lav-500);
          }
          /* submit button */
          .cycle-form .btn-submit {
            background: linear-gradient(135deg, var(--lav-500), #c026d3);
            color: white; border: none; border-radius: 12px;
            padding: 0.8rem 1.5rem; font-size: 0.95rem; font-weight: 600;
            width: 100%; cursor: pointer; transition: all 0.25s;
            box-shadow: 0 4px 16px rgba(139,92,246,0.3);
            font-family: var(--font-body);
          }
          .cycle-form .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 22px rgba(139,92,246,0.4);
          }
          /* stat mini cards */
          .stat-mini {
            text-align: center; padding: 0.85rem;
            background: linear-gradient(135deg, var(--lav-50), #fce7f3);
            border: 1px solid var(--lav-200);
            border-radius: 12px;
          }
          .stat-mini-val {
            font-family: var(--font-display); font-size: 1.6rem;
            font-weight: 700; color: var(--lav-700);
          }
          /* timeline */
          .timeline::before { background: var(--lav-200); }
          .timeline-item::before { background: var(--lav-400); border-color: white; }
        </style>

        <form action="/insights/cycle" method="POST" class="cycle-form">
          <div class="grid-2" style="gap:0.75rem;">
            <div class="form-group">
              <label>🗓️ Period Start Date</label>
              <input type="date" name="periodStartDate" required
                     value="<%= new Date().toISOString().split('T')[0] %>">
            </div>
            <div class="form-group">
              <label>🗓️ Period End Date</label>
              <input type="date" name="periodEndDate">
            </div>
          </div>

          <div class="form-group">
            <label>💧 Flow Level</label>
            <div class="option-card-grid" style="grid-template-columns:repeat(4,1fr);">
              <label class="option-card"><input type="radio" name="flowLevel" value="spotting"><span class="oc-icon">🩷</span><span class="oc-label">Spotting</span></label>
              <label class="option-card"><input type="radio" name="flowLevel" value="light"><span class="oc-icon">💧</span><span class="oc-label">Light</span></label>
              <label class="option-card"><input type="radio" name="flowLevel" value="medium" checked><span class="oc-icon">💦</span><span class="oc-label">Medium</span></label>
              <label class="option-card"><input type="radio" name="flowLevel" value="heavy"><span class="oc-icon">🌊</span><span class="oc-label">Heavy</span></label>
            </div>
          </div>

          <div class="form-group">
            <label>🌸 Symptoms <span style="font-weight:400;color:var(--text-muted);">(select all that apply)</span></label>
            <div class="option-card-grid">
              <label class="option-card"><input type="checkbox" name="symptoms" value="cramps"><span class="oc-icon">😖</span><span class="oc-label">Cramps</span></label>
              <label class="option-card"><input type="checkbox" name="symptoms" value="bloating"><span class="oc-icon">🫧</span><span class="oc-label">Bloating</span></label>
              <label class="option-card"><input type="checkbox" name="symptoms" value="headache"><span class="oc-icon">🤕</span><span class="oc-label">Headache</span></label>
              <label class="option-card"><input type="checkbox" name="symptoms" value="fatigue"><span class="oc-icon">😴</span><span class="oc-label">Fatigue</span></label>
              <label class="option-card"><input type="checkbox" name="symptoms" value="nausea"><span class="oc-icon">🤢</span><span class="oc-label">Nausea</span></label>
              <label class="option-card"><input type="checkbox" name="symptoms" value="backache"><span class="oc-icon">🦴</span><span class="oc-label">Backache</span></label>
            </div>
          </div>

          <div class="form-group">
            <label>🩸 Blood Clots?</label>
            <select name="hasClots">
              <option value="false">No</option>
              <option value="true">Yes</option>
            </select>
          </div>

          <div class="form-group">
            <label>💜 How are you feeling?</label>
            <div class="mood-grid">
              <button type="button" class="mood-btn" data-mood="happy">😊 Happy</button>
              <button type="button" class="mood-btn" data-mood="calm">😌 Calm</button>
              <button type="button" class="mood-btn" data-mood="irritable">😤 Irritable</button>
              <button type="button" class="mood-btn" data-mood="anxious">😰 Anxious</button>
              <button type="button" class="mood-btn" data-mood="sad">😔 Sad</button>
              <button type="button" class="mood-btn" data-mood="tired">😴 Tired</button>
            </div>
            <input type="hidden" name="mood" id="moodInput">
          </div>

          <div class="grid-2" style="gap:0.75rem;">
            <div class="form-group">
              <label>😣 Pain Level &nbsp;<span id="painVal" style="font-weight:700;color:var(--rose);">0</span>/10</label>
              <input type="range" id="painLevel" name="painLevel" min="0" max="10" value="0"
                     oninput="document.getElementById('painVal').textContent=this.value">
              <div class="flex justify-between text-sm text-muted mt-1">
                <span>None</span><span>Severe</span>
              </div>
            </div>
            <div class="form-group">
              <label>⚡ Energy Level &nbsp;<span id="energyVal" style="font-weight:700;color:var(--lav-600);">5</span>/10</label>
              <input type="range" id="energyLevel" name="energyLevel" min="1" max="10" value="5"
                     oninput="document.getElementById('energyVal').textContent=this.value">
              <div class="flex justify-between text-sm text-muted mt-1">
                <span>Drained</span><span>Energised</span>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label>📝 Notes</label>
            <textarea name="notes" placeholder="Any additional observations, feelings or patterns you noticed..."></textarea>
          </div>

          <button type="submit" class="btn-submit">🌸 Save Entry</button>
        </form>
      </div>

      <!-- ── RIGHT COLUMN: Stats + History ── -->
      <div style="display:flex;flex-direction:column;gap:1.25rem;">

        <!-- Cycle stats -->
        <% if (cycleStats) { %>
        <div class="card fade-up fade-up-2" style="border-color:var(--lav-200);">
          <div class="card-header">
            <div class="card-title">📊 Your Cycle Stats</div>
            <span class="phase-pill"><%= cycleStats.phase ? cycleStats.phase.name : 'Tracking' %></span>
          </div>
          <div class="grid-2" style="gap:0.75rem;">
            <div class="stat-mini">
              <div class="stat-mini-val"><%= cycleStats.avg %></div>
              <div class="text-sm text-muted">avg days</div>
            </div>
            <div class="stat-mini">
              <div class="stat-mini-val" style="color:<%= cycleStats.isIrregular ? '#be185d' : '#16a34a' %>;">
                <%= cycleStats.isIrregular ? '⚠️' : '✅' %>
              </div>
              <div class="text-sm text-muted"><%= cycleStats.isIrregular ? 'Irregular' : 'Regular' %></div>
            </div>
          </div>
          <div style="margin-top:0.85rem;padding:0.75rem;background:linear-gradient(135deg,var(--lav-50),#fce7f3);border-radius:10px;border:1px solid var(--lav-200);">
            <span style="font-size:0.82rem;color:var(--lav-700);font-weight:600;">⏭ Next estimated period: </span>
            <strong style="color:var(--lav-800);">
              <%= cycleStats.nextPeriod.toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %>
            </strong>
          </div>
        </div>
        <% } %>

        <!-- Phase tip -->
        <% if (cycleStats && cycleStats.phase) { %>
        <div class="card fade-up fade-up-2" style="background:linear-gradient(135deg,var(--lav-500),#9333ea,#c026d3);color:white;border:none;">
          <div style="font-size:0.75rem;opacity:0.8;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.35rem;">Current Phase</div>
          <div style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;margin-bottom:0.4rem;">
            <%= cycleStats.phase.emoji %> <%= cycleStats.phase.name %>
          </div>
          <div style="font-size:0.85rem;opacity:0.9;"><%= cycleStats.phase.tip %></div>
        </div>
        <% } %>

        <!-- Log history -->
        <div class="card fade-up fade-up-3" style="border-color:var(--lav-200);">
          <div class="card-header">
            <div class="card-title">📜 History</div>
            <span style="font-size:0.78rem;color:var(--lav-600);font-weight:600;background:var(--lav-50);padding:0.25rem 0.6rem;border-radius:99px;border:1px solid var(--lav-200);">
              <%= logs.length %> entries
            </span>
          </div>
          <% if (logs.length > 0) { %>
          <div class="timeline">
            <% logs.forEach(log => { %>
            <div class="timeline-item">
              <div class="timeline-date">
                <%= new Date(log.periodStartDate).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %>
              </div>
              <div class="timeline-content">
                <div class="flex gap-1" style="flex-wrap:wrap;margin-bottom:0.35rem;">
                  <% if (log.flowLevel) { %>
                  <span class="tag" style="background:var(--lav-100);color:var(--lav-800);">💧 <%= log.flowLevel %></span>
                  <% } %>
                  <% if (log.mood) { %>
                  <span class="tag" style="background:#fce7f3;color:#be185d;">💜 <%= log.mood %></span>
                  <% } %>
                  <% if (log.hasClots) { %>
                  <span class="tag" style="background:var(--rose-light);color:#be185d;">clots</span>
                  <% } %>
                </div>
                <% if (log.symptoms && log.symptoms.length > 0) { %>
                <div class="text-sm text-muted">🌸 <%= log.symptoms.join(', ') %></div>
                <% } %>
                <% if (log.notes) { %>
                <div class="text-sm text-muted mt-1" style="font-style:italic;">📝 <%= log.notes %></div>
                <% } %>
                <div style="display:flex;gap:0.5rem;margin-top:0.5rem;font-size:0.75rem;color:var(--text-muted);">
                  <% if (log.painLevel !== undefined) { %>
                  <span>😣 Pain: <strong><%= log.painLevel %>/10</strong></span>
                  <% } %>
                  <% if (log.energyLevel !== undefined) { %>
                  <span>⚡ Energy: <strong><%= log.energyLevel %>/10</strong></span>
                  <% } %>
                </div>
                <form action="/insights/cycle/delete/<%= log._id %>" method="POST" style="margin-top:0.5rem;">
                  <button class="btn btn-sm" type="submit"
                          onclick="return confirm('Delete this entry?')"
                          style="background:#fce7f3;color:#be185d;border:1px solid #f9a8d4;border-radius:8px;">
                    🗑 Delete
                  </button>
                </form>
              </div>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <div class="empty-state">
            <div class="empty-icon">🌸</div>
            <p>No cycle logs yet.<br>Log your first period above!</p>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
document.querySelectorAll('.mood-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.mood-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('moodInput').value = btn.dataset.mood;
  });
});
</script>

<%- include('../partials/footer') %>
