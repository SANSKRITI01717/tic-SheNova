<!DOCTYPE html>
<html>
<head>
  <title>Herlytics</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="page-container">

  <div class="card">
    <h2>Find a gynecologist</h2>

    <form action="/doctor" method="GET" class="search-form">
      <input type="text" name="city" value="<%= cityQuery %>"
        placeholder="Enter city (Bhopal, Indore)" />
      <button class="btn-primary">Search</button>
    </form>
  </div>

  <% if (clinics.length > 0) { %>

    <div class="doctor-grid">
      <% clinics.forEach(clinic => { %>

        <div class="doctor-card">
          <div class="doctor-avatar">
            <%= clinic.name.charAt(0) %>
          </div>

          <div>
            <h3><%= clinic.name %></h3>
            <p><%= clinic.specialty %></p>

            <p>🏥 <%= clinic.hospital %></p>
            <p>📍 <%= clinic.address %></p>
            <p>📞 <%= clinic.phone %></p>

            <a href="tel:<%= clinic.phone %>" class="btn-call">
              Call
            </a>
          </div>
        </div>

      <% }) %>
    </div>

    <% if (lat && lng) { %>
      <div class="card">
        <h3>Map view</h3>

        <iframe
          width="100%"
          height="350"
          src="https://www.openstreetmap.org/export/embed.html?bbox=<%= lng-0.08 %>,<%= lat-0.08 %>,<%= lng+0.08 %>,<%= lat+0.08 %>&layer=mapnik&marker=<%= lat %>,<%= lng %>">
        </iframe>

        <!-- FIXED LINK -->
        <a href="https://www.openstreetmap.org/?mlat=<%= lat %>&mlon=<%= lng %>#map=13/<%= lat %>/<%= lng %>"
           target="_blank">
          Open full map →
        </a>

      </div>
    <% } %>

  <% } else if (cityQuery) { %>

    <div class="card">
      <h3>No results for "<%= cityQuery %>"</h3>
      <p>Try Bhopal or Indore</p>
    </div>

  <% } %>

</div>

    </body>
</html>