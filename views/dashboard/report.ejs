<!DOCTYPE html>
<html>
<head>
  <title>Herlytics</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar', { activePage: 'report' }) %>
  <main class="main-content">
    <div class="flex justify-between items-center mb-3">
      <div>
        <h1 style="font-family:var(--font-display);font-size:1.6rem;">📋 Health Report</h1>
        <p class="text-muted text-sm">Generated on <%= new Date().toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></p>
      </div>
      <a href="/doctor/share" class="btn btn-primary">Share with Doctor →</a>
    </div>

    <!-- Overview -->
    <div class="grid-3 mb-3">
      <div class="stat-card fade-up">
        <div class="stat-icon">🔬</div>
        <div class="stat-label">PCOS Risk Score</div>
        <div class="stat-value"><%= user.riskScore %></div>
        <div class="stat-meta"><span class="risk-badge risk-<%= user.riskLevel %>"><%= user.riskLevel %> risk</span></div>
      </div>
      <div class="stat-card fade-up fade-up-2">
        <div class="stat-icon">📅</div>
        <div class="stat-label">Avg Cycle Length</div>
        <div class="stat-value"><%= cycleStats ? cycleStats.avg : '—' %></div>
        <div class="stat-meta"><%= cycleStats ? 'days' : 'No data yet' %></div>
      </div>
      <div class="stat-card fade-up fade-up-3">
        <div class="stat-icon">📝</div>
        <div class="stat-label">Total Logs</div>
        <div class="stat-value"><%= cycleLogs.length %></div>
        <div class="stat-meta">cycle entries</div>
      </div>
    </div>

    <div class="grid-2 mb-3">
      <!-- Cycle history -->
      <div class="card fade-up">
        <div class="card-header"><div class="card-title">🌙 Cycle History</div></div>
        <% if (cycleLogs.length > 0) { %>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Date</th><th>Flow</th><th>Pain</th><th>Mood</th></tr></thead>
            <tbody>
              <% cycleLogs.forEach(log => { %>
              <tr>
                <td><%= new Date(log.periodStartDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
                <td><span class="tag"><%= log.flowLevel || 'N/A' %></span></td>
                <td><%= log.painLevel !== undefined ? log.painLevel + '/10' : '—' %></td>
                <td><%= log.mood || '—' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="empty-state"><div class="empty-icon">🌙</div><p>No cycle logs yet.</p></div>
        <% } %>
      </div>

      <!-- Nutrition summary -->
      <div class="card fade-up fade-up-2">
        <div class="card-header"><div class="card-title">🥗 Nutrition (Last 7 Days)</div></div>
        <% if (nutritionLogs.length > 0) { %>
        <% const avgCal = Math.round(nutritionLogs.reduce((s,l)=>s+(l.totalCalories||0),0)/nutritionLogs.length); %>
        <% const avgWater = Math.round(nutritionLogs.reduce((s,l)=>s+(l.waterGlasses||0),0)/nutritionLogs.length); %>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          <div>
            <div class="flex justify-between text-sm mb-1"><span>Avg Calories</span><span class="fw-600"><%= avgCal %> kcal</span></div>
            <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:<%= Math.min(avgCal/1800*100,100) %>%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span>Avg Water</span><span class="fw-600"><%= avgWater %> glasses</span></div>
            <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:<%= Math.min(avgWater/8*100,100) %>%"></div></div>
          </div>
        </div>
        <% } else { %>
        <div class="empty-state"><div class="empty-icon">🥗</div><p>No nutrition logs yet.</p></div>
        <% } %>
      </div>
    </div>

    <!-- Risk flags -->
    <div class="card fade-up mb-3">
      <div class="card-header"><div class="card-title">⚠️ Identified Risk Factors</div></div>
      <% if (user.riskFlags && user.riskFlags.length > 0) { %>
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        <% user.riskFlags.forEach(f => { %>
        <span class="tag" style="background:var(--rose-light);color:#be185d;font-size:0.82rem;padding:0.3rem 0.75rem;">⚑ <%= f %></span>
        <% }) %>
      </div>
      <% } else { %>
      <div class="alert alert-success">✅ No major risk flags detected based on your assessment.</div>
      <% } %>
    </div>

    <!-- Profile summary -->
    <div class="card fade-up">
      <div class="card-header"><div class="card-title">👤 Profile Summary</div></div>
      <div class="grid-2">
        <div style="display:flex;flex-direction:column;gap:0.6rem;">
          <div class="flex gap-2"><span class="text-muted text-sm">Name</span><span class="fw-600"><%= user.name %></span></div>
          <div class="flex gap-2"><span class="text-muted text-sm">Age</span><span class="fw-600"><%= user.age %></span></div>
          <div class="flex gap-2"><span class="text-muted text-sm">City</span><span class="fw-600"><%= user.city || 'Not specified' %></span></div>
          <div class="flex gap-2"><span class="text-muted text-sm">Cycle Gap</span><span class="fw-600"><%= user.cycleGap || 'Not specified' %></span></div>
          <div class="flex gap-2"><span class="text-muted text-sm">Tracking for</span>
            <span class="fw-600">
              <%= user.trackingFor === 'myself' ? '🌸 Myself' : user.trackingFor === 'someone_i_love' ? '💕 Someone I love' : user.trackingFor === 'family_member' ? '👨‍👩‍👧 A family member' : 'Not set' %>
            </span>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.6rem;">
          <div class="flex gap-2"><span class="text-muted text-sm">Stress</span><span class="fw-600"><%= user.stressLevel || 'N/A' %></span></div>
          <div class="flex gap-2"><span class="text-muted text-sm">Sleep</span><span class="fw-600"><%= user.sleepPattern || 'N/A' %></span></div>
          <div class="flex gap-2"><span class="text-muted text-sm">Activity</span><span class="fw-600"><%= user.activityLevel || 'N/A' %></span></div>
          <div class="flex gap-2"><span class="text-muted text-sm">Diet</span><span class="fw-600"><%= user.dietPattern || 'N/A' %></span></div>
        </div>
      </div>
    </div>
  </main>
</div>

</body>
</html>