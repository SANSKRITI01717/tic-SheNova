<!DOCTYPE html>
<html>
<head>
  <title>Herlytics</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-wrap" style="min-height:calc(100vh - 64px);">
  <div class="auth-card" style="max-width:380px;">
    <div class="auth-logo">
      <div class="logo-mark">🔐</div>
      <h2>Quick Access PIN</h2>
      <p>Set a 4-digit PIN for faster login</p>
    </div>

    <% if (flash && flash.type === 'success') { %>
    <div class="alert alert-success">✅ <%= flash.message %></div>
    <% } %>

    <% if (!hasPin) { %>
    <form action="/pin/set" method="POST">
      <div class="form-group">
        <label>Choose a 4-digit PIN</label>
        <input type="password" name="pin" pattern="\d{4}" maxlength="4" placeholder="••••" style="font-size:1.5rem;letter-spacing:0.5rem;text-align:center;" required>
        <p class="form-hint">Use a PIN you'll remember. It's stored securely.</p>
      </div>
      <button class="btn btn-primary btn-block">Set PIN</button>
    </form>
    <% } else { %>
    <div class="alert alert-success">✅ You already have a PIN set.</div>
    <form action="/pin/set" method="POST">
      <div class="form-group">
        <label>Update your PIN</label>
        <input type="password" name="pin" pattern="\d{4}" maxlength="4" placeholder="••••" style="font-size:1.5rem;letter-spacing:0.5rem;text-align:center;" required>
      </div>
      <button class="btn btn-outline btn-block">Update PIN</button>
    </form>
    <% } %>

    <div class="auth-switch mt-2">
      <a href="/dashboard">← Back to Dashboard</a>
    </div>
  </div>
</div>

</body>
</html>
