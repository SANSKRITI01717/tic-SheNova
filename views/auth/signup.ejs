<!DOCTYPE html>
<html>
<head>
  <title>Herlytics</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<style>
.auth-wrap {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #f5f0ff 0%, #fce7f3 50%, #ede5ff 100%);
  padding: 2rem; position: relative; overflow: hidden;
}
.auth-wrap::before {
  content: '';
  position: absolute; top: -100px; left: -100px;
  width: 420px; height: 420px; border-radius: 50%;
  background: radial-gradient(circle, rgba(192,38,211,0.08), transparent 70%);
  pointer-events: none;
}
.auth-wrap::after {
  content: '';
  position: absolute; bottom: -120px; right: -80px;
  width: 380px; height: 380px; border-radius: 50%;
  background: radial-gradient(circle, rgba(139,92,246,0.10), transparent 70%);
  pointer-events: none;
}

.auth-card {
  width: 100%; max-width: 500px;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1.5px solid rgba(255,255,255,0.9);
  border-radius: 24px; padding: 2.5rem;
  box-shadow: 0 8px 48px rgba(139,92,246,0.15), 0 2px 12px rgba(236,72,153,0.08);
  position: relative; z-index: 1;
  animation: floatUp 0.6s cubic-bezier(0.4,0,0.2,1) both;
}
@keyframes floatUp {
  from { opacity:0; transform: translateY(30px); }
  to   { opacity:1; transform: translateY(0); }
}
.auth-card::before {
  content: '🌺';
  position: absolute; top: -14px; left: 24px;
  font-size: 1.5rem;
  animation: petalFloat 3.5s ease-in-out infinite;
}
.auth-card::after {
  content: '💜';
  position: absolute; top: 10px; right: -4px;
  font-size: 1rem;
  animation: petalFloat 4s ease-in-out infinite reverse;
}
@keyframes petalFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50%       { transform: translateY(-6px) rotate(10deg); }
}

.auth-logo { text-align: center; margin-bottom: 1.75rem; }
.auth-logo a { text-decoration: none; }
.auth-logo .logo-mark {
  width: 62px; height: 62px; border-radius: 18px;
  background: linear-gradient(135deg, var(--lav-300), var(--lav-600), #c026d3);
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 1.85rem; margin-bottom: 0.9rem;
  box-shadow: 0 4px 20px rgba(139,92,246,0.3);
  transition: transform 0.3s;
}
.auth-logo .logo-mark:hover { transform: rotate(-10deg) scale(1.05); }
.auth-logo h2 {
  font-family: var(--font-display); font-size: 1.7rem; font-weight: 700;
  background: linear-gradient(135deg, var(--lav-600), #c026d3);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; margin-bottom: 0.3rem;
}
.auth-logo p { font-size: 0.88rem; color: var(--text-muted); }

.auth-card label {
  font-size: 0.82rem; font-weight: 600; color: var(--lav-800); margin-bottom: 0.4rem;
}
.auth-card input[type="text"],
.auth-card input[type="email"],
.auth-card input[type="password"],
.auth-card input[type="number"] {
  background: rgba(245,240,255,0.6);
  border: 1.5px solid var(--lav-200);
  border-radius: 12px; padding: 0.75rem 1rem;
  font-size: 0.9rem; color: var(--text);
  transition: all 0.2s;
}
.auth-card input:focus {
  border-color: var(--lav-400);
  background: white;
  box-shadow: 0 0 0 4px rgba(139,92,246,0.1);
}
.auth-card input::placeholder { color: #c4b5fd; }

.auth-card .btn-primary {
  background: linear-gradient(135deg, var(--lav-500), #c026d3);
  border-radius: 12px; font-size: 0.95rem;
  box-shadow: 0 4px 18px rgba(139,92,246,0.35);
  letter-spacing: 0.02em; transition: all 0.25s;
}
.auth-card .btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(139,92,246,0.45);
}

.privacy-note {
  display: flex; align-items: center; gap: 0.5rem; justify-content: center;
  font-size: 0.75rem; color: var(--text-muted);
  margin-top: 0.75rem;
  background: var(--lav-50); border-radius: 8px; padding: 0.5rem 0.75rem;
  border: 1px solid var(--lav-100);
}

.auth-switch { text-align: center; font-size: 0.85rem; color: var(--text-muted); margin-top: 1rem; }
.auth-switch a {
  font-weight: 600; text-decoration: none;
  background: linear-gradient(135deg, var(--lav-600), #c026d3);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}

.petal {
  position: fixed; pointer-events: none; z-index: 0;
  font-size: 1.2rem; opacity: 0.18;
  animation: drift linear infinite;
}
@keyframes drift {
  0%   { transform: translateY(-30px) rotate(0deg);   opacity: 0; }
  10%  { opacity: 0.18; }
  90%  { opacity: 0.12; }
  100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
}
</style>

<!-- Floating petals -->
<div class="petal" style="left:5%;animation-duration:13s;animation-delay:0s;top:-30px;">🌸</div>
<div class="petal" style="left:18%;animation-duration:16s;animation-delay:2s;top:-30px;font-size:0.8rem;">💜</div>
<div class="petal" style="left:40%;animation-duration:11s;animation-delay:3s;top:-30px;">🌺</div>
<div class="petal" style="left:60%;animation-duration:14s;animation-delay:1s;top:-30px;font-size:0.9rem;">✨</div>
<div class="petal" style="left:78%;animation-duration:12s;animation-delay:4s;top:-30px;">🌸</div>
<div class="petal" style="left:90%;animation-duration:15s;animation-delay:2s;top:-30px;font-size:0.75rem;">💕</div>

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">
      <a href="/">
        <div class="logo-mark">🌸</div>
        <h2>Herlytics</h2>
        <p>Your cycle, your story 💜 Let's begin</p>
      </a>
    </div>

    <% if (error) { %>
    <div class="alert alert-error" style="border-radius:12px;">⚠️ <%= error %></div>
    <% } %>

    <form action="/signup" method="POST">
      <div class="grid-2" style="gap:0.75rem;">
        <div class="form-group">
          <label for="name">🌸 &nbsp;Full Name</label>
          <input type="text" id="name" name="name" placeholder="Priya Sharma" required>
        </div>
        <div class="form-group">
          <label for="age">🎂 &nbsp;Age</label>
          <input type="number" id="age" name="age" min="13" max="60" placeholder="25" required>
        </div>
      </div>
      <div class="form-group">
        <label for="email">✉️ &nbsp;Email Address</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
      </div>
      <div class="form-group">
        <label for="city">📍 &nbsp;City</label>
        <input type="text" id="city" name="city" placeholder="Mumbai">
      </div>
      <div class="form-group">
        <label for="password">🔒 &nbsp;Password</label>
        <input type="password" id="password" name="password"
               placeholder="Min 8 characters" minlength="8" required>
      </div>

      <button type="submit" class="btn btn-primary btn-block btn-lg" style="margin-top:0.75rem;">
        Create My Account &nbsp;🌸
      </button>
    </form>

    <div class="privacy-note">
      🔒 Your data is private, encrypted, and never sold. Ever.
    </div>

    <div class="auth-switch">
      Already have an account? <a href="/login">Sign in here</a>
    </div>
  </div>
</div>

</body>
</html>