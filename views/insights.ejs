<!DOCTYPE html>
<html>
<head>
  <title>Herlytics</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="page-container">

  <div class="page-hero">
    <div>
      <h2>Your profile</h2>
      <p>Update your information and health answers anytime.</p>
    </div>
  </div>

  <% if (success) { %>
    <div class="alert success">✅ <%= success %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error">⚠️ <%= error %></div>
  <% } %>

  <!-- Basic Info -->
  <div class="card">
    <div class="card-title">Basic information</div>

    <form action="/profile/update" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label>Full name</label>
          <input type="text" name="name" value="<%= user?.name || '' %>" required />
        </div>

        <div class="form-group">
          <label>Username</label>
          <input type="text" value="@<%= user?.username %>" disabled />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Age</label>
          <input type="number" name="age" min="10" max="65"
            value="<%= user?.age || '' %>" />
        </div>

        <div class="form-group">
          <label>City</label>
          <input type="text" name="city"
            value="<%= user?.city || '' %>" />
        </div>
      </div>

      <% if (user?.age) { %>
        <div class="age-insight-box">
          <% if (user.age >= 45) { %>
            <span class="age-tag">🌙 Perimenopause range</span>
            <p>Hormonal shifts may begin — irregular cycles are common.</p>
          <% } else if (user.age <= 17) { %>
            <span class="age-tag">🌱 Teen cycle</span>
            <p>Irregular cycles are normal early on.</p>
          <% } else { %>
            <span class="age-tag">✅ Reproductive years</span>
            <p>Healthy cycles are typically 21–35 days.</p>
          <% } %>
        </div>
      <% } %>

      <button class="btn-primary">Save changes</button>
    </form>
  </div>

  <!-- Health Profile -->
  <div class="card">
    <div class="card-title">Health profile</div>

    <form action="/profile/health" method="POST">

      <!-- Cycle -->
      <div class="form-group">
        <label>Cycle length</label>
        <div class="radio-group">
          <% ['21-25','26-30','31-35','more35','irregular'].forEach(val => { %>
            <label>
              <input type="radio" name="cycleGap" value="<%= val %>"
                <%= user?.cycleGap === val ? 'checked' : '' %>>
              <%= val %>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- Symptoms -->
      <div class="form-group">
        <label>Physical symptoms</label>
        <div class="checkbox-group">
          <% ['cramps','heavy_flow','bloating','headaches','facial_hair'].forEach(s => { %>
            <label>
              <input type="checkbox" name="physicalSymptoms" value="<%= s %>"
                <%= user?.physicalSymptoms?.includes(s) ? 'checked' : '' %>>
              <%= s.replace('_',' ') %>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- Stress -->
      <div class="form-group">
        <label>Stress level</label>
        <select name="stressLevel">
          <option value="low">Low</option>
          <option value="moderate">Moderate</option>
          <option value="high">High</option>
        </select>
      </div>

      <button class="btn-primary">Update health</button>
    </form>
  </div>

</div>


    </body>
</html>